{
  "name": "@mindstudio-ai/agent",
  "version": "0.1.21",
  "description": "TypeScript SDK for MindStudio direct step execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "mindstudio": "./dist/cli.js"
  },
  "files": [
    "dist",
    "llms.txt"
  ],
  "scripts": {
    "build": "npm run codegen && tsup",
    "build:local": "MINDSTUDIO_BASE_URL=http://localhost:3129 npm run build",
    "dev": "tsup --watch",
    "codegen": "tsx scripts/codegen.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "node dist/postinstall.js || true",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mindstudio",
    "ai",
    "workflow",
    "automation",
    "sdk"
  ],
  "homepage": "https://github.com/mindstudio-ai/mindstudio-agent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mindstudio-ai/mindstudio-agent.git"
  },
  "bugs": {
    "url": "https://github.com/mindstudio-ai/mindstudio-agent/issues"
  },
  "author": "MindStudio <support@mindstudio.ai> (https://mindstudio.ai)",
  "license": "MIT",
  "browser": {
    "fs": false,
    "path": false,
    "os": false,
    "node:fs": false,
    "node:path": false,
    "node:os": false
  },
  "sideEffects": false,
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.2",
    "prettier": "^3.8.1",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5.5"
  }
}
